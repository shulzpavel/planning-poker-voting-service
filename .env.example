VOTING_SERVICE_PORT=8002
REDIS_URL=redis://localhost:6379/0
# CMS Postgres pool (voting-service)
CMS_DB_POOL_MIN=2
CMS_DB_POOL_MAX=20

JIRA_SERVICE_URL=http://localhost:8001
CMS_USERNAME=admin
CMS_PASSWORD=
# CMS auth cookie Secure flag. Unset = true outside APP_ENV=dev|local|test.
# Local HTTP dev: CMS_COOKIE_SECURE=false
CMS_COOKIE_SECURE=false
# CMS session absolute lifetime in seconds (default 86400).
CMS_TOKEN_TTL_SECONDS=86400
